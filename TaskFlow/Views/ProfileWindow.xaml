<Window x:Class="TaskFlow.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        Title="TaskFlow — Profilim"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.DataContext>
        <vm:ProfileViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                      Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Menü -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,32,0,40">
                    <TextBlock Text="⚡ TaskFlow"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RoleDisplay}"
                               FontSize="11" Foreground="#95A5A6"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,0">
                    <Border Background="#34495E" CornerRadius="8" Margin="0,2">
                        <TextBlock Text="👤  Profilim"
                                   Foreground="White" FontSize="13"
                                   Padding="16,12"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,24">
                    <TextBlock Text="{Binding FullName}"
                               Foreground="#BDC3C7" FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <Button Content="Çıkış Yap"
                            Command="{Binding LogoutCommand}"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Height="36"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Ana İçerik -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,32,32,32">

                <!-- Profil Kartı -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                Width="80" Height="80"
                                CornerRadius="40"
                                Background="#3498DB"
                                Margin="0,0,24,0">
                            <TextBlock Text="{Binding AvatarLetter}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Bilgiler -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding FullName}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding Username}"
                                       FontSize="13" Foreground="#7F8C8D"
                                       Margin="0,4,0,8"/>
                            <Border Background="#EBF5FB"
                                    CornerRadius="4"
                                    Padding="10,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding RoleDisplay}"
                                           Foreground="#3498DB"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Detay Bilgiler -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,32,0">
                            <TextBlock Text="DEPARTMAN"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding DepartmentName}"
                                       Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="KULLANICI ADI"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding Username}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TAKIM"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding TeamName}"
                                       Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="ROL"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding RoleDisplay}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Projelerim -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📁 Projelerim"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,16"/>

                        <!-- Proje Kartları -->
                        <ItemsControl ItemsSource="{Binding MyProjects}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA"
                                            CornerRadius="10"
                                            Padding="20"
                                            Margin="0,0,12,12"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ProjectCard_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- Proje ikonu -->
                                            <Border Background="#3498DB"
                                                    CornerRadius="8"
                                                    Width="40" Height="40"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12">
                                                <TextBlock Text="📁"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="#2C3E50"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,4"/>

                                            <TextBlock Text="{Binding Team.Name}"
                                                       FontSize="12"
                                                       Foreground="#7F8C8D"
                                                       Margin="0,0,0,12"/>

                                            <!-- Durum etiketi -->
                                            <Border CornerRadius="4"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F8F5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="OnHold">
                                                                <Setter Property="Background" Value="#FEF9E7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="Completed">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#27AE60"/>
                                            </Border>

                                            <TextBlock Text="Detayları görüntüle →"
                                                       FontSize="11"
                                                       Foreground="#3498DB"
                                                       Margin="0,12,0,0"
                                                       Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Proje yoksa -->
                        <Border Background="#F8F9FA"
                                CornerRadius="10"
                                Padding="40">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MyProjects.Count}"
                                                     Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📭"
                                           FontSize="32"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Henüz bir projeye atanmadınız."
                                           Foreground="#7F8C8D"
                                           FontSize="13"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>