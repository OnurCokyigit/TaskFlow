<Window x:Class="TaskFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        Title="TaskFlow" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Ana renkler -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="LightColor" Color="#ECF0F1"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#E74C3C"/>

        <!-- Input stil -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Şifre input stil -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Buton stil -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A6FA8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Sol panel - Koyu arka plan -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol: Marka alanı -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center">
                <TextBlock Text="⚡" FontSize="52" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="TaskFlow" 
                           FontSize="36" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Kurumsal Görev Yönetim Sistemi" 
                           FontSize="13"
                           Foreground="#95A5A6"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <Rectangle Height="2" Width="60" 
                           Fill="#3498DB" 
                           Margin="0,24,0,24"/>
                <TextBlock Text="Ekibinizle birlikte daha&#x0a;verimli çalışın." 
                           FontSize="13"
                           Foreground="#BDC3C7"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- Sağ: Login formu -->
        <Border Grid.Column="1" Background="#F5F6FA">
            <StackPanel VerticalAlignment="Center" 
                        Margin="50,0">

                <TextBlock Text="Hoş Geldiniz" 
                           FontSize="26" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Devam etmek için giriş yapın." 
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,36"/>

                <!-- Kullanıcı adı -->
                <TextBlock Text="KULLANICI ADI" 
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,6"
                           />
                <TextBox Style="{StaticResource PlaceholderTextBox}"
                         Tag="Kullanıcı adınızı girin"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20"/>

                <!-- Şifre -->
                <TextBlock Text="ŞİFRE" 
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordInput"
                             Style="{StaticResource PasswordStyle}"
                             Margin="0,0,0,8"
                             KeyDown="PasswordInput_KeyDown"/>

                <!-- Hata mesajı -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontSize="12"
                           Margin="0,0,0,20"
                           Visibility="{Binding ErrorMessage, 
                                        Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Giriş butonu -->
                <Button Content="{Binding IsLoading, 
                                Converter={StaticResource LoadingTextConverter}}"
                        Style="{StaticResource LoginButtonStyle}"
                        Command="{Binding LoginCommand}"
                        Click="LoginButton_Click"
                        IsEnabled="{Binding IsLoading, 
                                   Converter={StaticResource InverseBoolConverter}}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>