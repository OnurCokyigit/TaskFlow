<Window x:Class="TaskFlow.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        Title="TaskFlow — Dashboard"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.DataContext>
        <vm:DashboardViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                      Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Menü -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,32,0,40">
                    <TextBlock Text="⚡ TaskFlow"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RoleDisplay}"
                               FontSize="11" Foreground="#95A5A6"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,0">
                    <Border Background="#34495E" CornerRadius="8" Margin="0,2">
                        <TextBlock Text="🏠  Dashboard"
                                   Foreground="White" FontSize="13"
                                   Padding="16,12"/>
                    </Border>
                    <Border CornerRadius="8" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonUp="OpenAdmin_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#34495E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="⚙️  Yönetim Paneli"
                                   Foreground="#BDC3C7" FontSize="13"
                                   Padding="16,12"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,24">
                    <TextBlock Text="{Binding FullName}"
                               Foreground="#BDC3C7" FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <Button Content="Çıkış Yap"
                            Command="{Binding LogoutCommand}"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Height="36"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Ana İçerik -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,32,32,32">

                <!-- Başlık -->
                <TextBlock FontSize="22" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,4">
                    <Run Text="Hoş geldin, "/>
                    <Run Text="{Binding FullName}" Foreground="#3498DB"/>
                </TextBlock>
                <TextBlock Text="İşte güncel durumun:"
                           Foreground="#7F8C8D" FontSize="13"
                           Margin="0,0,0,28"/>

                <!-- İstatistik Kartları -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalProjects}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Toplam Proje"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalTasks}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Toplam Görev"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding InProgressTasks}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#F39C12"/>
                            <TextBlock Text="Devam Eden"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="✅" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CompletedTasks}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2ECC71"/>
                            <TextBlock Text="Tamamlanan"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource StatCard}"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalUsers}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Kullanıcı"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Genel Tamamlanma Oranı -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📊 Genel Tamamlanma Oranı"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CompletionRateDisplay}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#3498DB"/>
                        </Grid>

                        <ProgressBar Height="12"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding CompletionRate}"
                                     Background="#ECF0F1"
                                     Foreground="#3498DB"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Background="#EBF5FB" CornerRadius="4"
                                    Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Foreground="#3498DB" FontSize="12">
                                    <Run Text="📌 Yapılacak: "/>
                                    <Run Text="{Binding TodoTasks}"
                                         FontWeight="Bold"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#FEF9E7" CornerRadius="4"
                                    Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Foreground="#F39C12" FontSize="12">
                                    <Run Text="⚡ Devam Eden: "/>
                                    <Run Text="{Binding InProgressTasks}"
                                         FontWeight="Bold"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#E8F8F5" CornerRadius="4"
                                    Padding="10,4">
                                <TextBlock Foreground="#27AE60" FontSize="12">
                                    <Run Text="✅ Tamamlanan: "/>
                                    <Run Text="{Binding CompletedTasks}"
                                         FontWeight="Bold"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Proje Özetleri -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📁 Proje Durumları"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding ProjectSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,12"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ProjectCard_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding TeamName}"
                                                           Foreground="#7F8C8D"
                                                           FontSize="11"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="16,0">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Text="{Binding ProgressDisplay}"
                                                        Foreground="#7F8C8D"
                                                        FontSize="11"
                                                        Grid.Column="1"/>
                                                </Grid>
                                                <ProgressBar
                                                    Height="8"
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding Progress}"
                                                    Background="#ECF0F1"
                                                    Foreground="#3498DB"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#7F8C8D"
                                                           FontSize="11">
                                                    <Run Text="{Binding CompletedTasks}"/>
                                                    <Run Text="/"/>
                                                    <Run Text="{Binding TotalTasks}"/>
                                                    <Run Text=" görev tamamlandı"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="Completed">
                                                                <Setter Property="Background" Value="#E8F8F5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="OnHold">
                                                                <Setter Property="Background" Value="#FEF9E7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#3498DB"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Henüz proje bulunmuyor."
                                   Foreground="#BDC3C7" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProjectSummaries.Count}"
                                                     Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Son Commitler -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📜 Son Aktiviteler"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding RecentCommits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    CornerRadius="16"
                                                    Background="#2C3E50">
                                                <TextBlock Text="{Binding User.FullName[0]}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Message}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding User.FullName}"
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"/>
                                                    <TextBlock Text=" · "
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Project.Title}"
                                                               Foreground="#3498DB"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="#EBF5FB"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock
                                                    Text="{Binding Progress,
                                                           StringFormat={}{0}/10}"
                                                    Foreground="#3498DB"
                                                    FontWeight="Bold"
                                                    FontSize="12"/>
                                            </Border>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding CreatedAt,
                                                              StringFormat=dd.MM.yyyy HH:mm}"
                                                       Foreground="#7F8C8D"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Henüz aktivite bulunmuyor."
                                   Foreground="#BDC3C7" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentCommits.Count}"
                                                     Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Son Kullanıcılar (sadece Admin) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Son Eklenen Kullanıcılar"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding RecentUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="18"
                                                    Background="#3498DB">
                                                <TextBlock Text="{Binding FullName[0]}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding FullName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding Team.Name}"
                                                           Foreground="#7F8C8D"
                                                           FontSize="11"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="#EBF5FB"
                                                    CornerRadius="4"
                                                    Padding="8,4">
                                                <TextBlock Text="{Binding Role}"
                                                           Foreground="#3498DB"
                                                           FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>