<Window x:Class="TaskFlow.Views.ProjectDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        Title="TaskFlow — Proje Detayı"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                      Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProgressBox" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KanbanCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                      Opacity="0.1" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst Bar -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ProjectTitleText"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="TeamNameText"
                                   FontSize="12" Foreground="#95A5A6"/>
                        <TextBlock Text=" · " Foreground="#95A5A6" FontSize="12"/>
                        <TextBlock x:Name="StartDateText"
                                   FontSize="12" Foreground="#95A5A6"/>
                        <TextBlock Text=" · Kaptan: " Foreground="#95A5A6" FontSize="12"/>
                        <TextBlock x:Name="LeaderText"
                                   FontSize="12" Foreground="#3498DB"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Geri"
                        Background="#34495E"
                        Foreground="White"
                        BorderThickness="0"
                        Height="36"
                        Padding="16,0"
                        Cursor="Hand"
                        Click="GoBack_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C3E50"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Ana İçerik -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32" x:Name="MainContent">

                <!-- Üyeler -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Takım Üyeleri"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,12"/>
                        <ItemsControl x:Name="MembersList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,16,0"
                                                HorizontalAlignment="Center">
                                        <Border Width="44" Height="44"
                                                CornerRadius="22"
                                                Background="#3498DB"
                                                Margin="0,0,0,6">
                                            <TextBlock Text="{Binding User.FullName[0]}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding User.FullName}"
                                                   FontSize="11"
                                                   Foreground="#2C3E50"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="60"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Görevler: Sekme -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📋 Görevler"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Sekme başlıkları -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border x:Name="ListTab"
                                    Background="#3498DB" CornerRadius="6"
                                    Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ShowListView">
                                <TextBlock Text="📋 Liste" Foreground="White" FontSize="13"/>
                            </Border>
                            <Border x:Name="KanbanTab"
                                    Background="#ECF0F1" CornerRadius="6"
                                    Padding="16,8" Cursor="Hand"
                                    MouseLeftButtonUp="ShowKanbanView">
                                <TextBlock Text="🗂 Kanban" Foreground="#7F8C8D" FontSize="13"/>
                            </Border>
                        </StackPanel>

                        <!-- Liste Görünümü -->
                        <StackPanel x:Name="ListViewPanel">
                            <ItemsControl x:Name="AllTasksList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA"
                                                CornerRadius="8"
                                                Padding="16,12"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#2C3E50"/>
                                                    <TextBlock Text="{Binding AssignedUser.FullName}"
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        CornerRadius="4"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FDEBD0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Priority}" Value="High">
                                                                    <Setter Property="Background" Value="#FADBD8"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                                    <Setter Property="Background" Value="#F1948A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                                    <Setter Property="Background" Value="#D5F5E3"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Priority}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#2C3E50"/>
                                                </Border>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Status}"
                                                           Foreground="#3498DB"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding DueDate,
                                                                  StringFormat=dd.MM.yyyy}"
                                                           Foreground="#7F8C8D"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoTasksText"
                                       Text="Henüz görev eklenmemiş."
                                       Foreground="#BDC3C7"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,16"
                                       Visibility="Collapsed"/>

                            <!-- Tamamlanan Görevler Arşivi -->
                            <Border Background="#F0FFF4"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,16,0,0">
                                <Expander Header="✅ Tamamlanan Görevler Arşivi"
                                  Foreground="#27AE60"
                                  FontWeight="SemiBold">
                                    <ItemsControl x:Name="DoneTasksList"
                                        Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White"
                                                    CornerRadius="6"
                                                    Padding="12,10"
                                                    Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#2C3E50"
                                                               TextDecorations="Strikethrough"/>
                                                            <TextBlock Text="{Binding AssignedUser.FullName}"
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="1"
                                                            Background="#D5F5E3"
                                                            CornerRadius="4"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center">
                                                            <TextBlock Text="Tamamlandı"
                                                               Foreground="#27AE60"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="2"
                                                           Text="{Binding DueDate,
                                                                  StringFormat=dd.MM.yyyy}"
                                                           Foreground="#7F8C8D"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </Border>

                        </StackPanel>

                        <!-- Kanban Görünümü -->
                        <Grid x:Name="KanbanViewPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Yapılacak -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Border Background="#EBF5FB" CornerRadius="8"
                                        Padding="12,8" Margin="0,0,0,8">
                                    <TextBlock Text="📌 Yapılacak"
                                               FontWeight="SemiBold"
                                               Foreground="#2980B9"/>
                                </Border>
                                <ItemsControl x:Name="TodoList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                Cursor="Hand"
                                                Tag="{Binding}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="⚡ Devam Ediyor'a Taşı"
                                                          Click="MoveToInProgress_Click"
                                                          Tag="{Binding}"/>
                                                        <MenuItem Header="✅ Tamamlandı'ya Taşı"
                                                          Click="MoveToDone_Click"
                                                          Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2C3E50"
                                                       FontSize="13"/>
                                                    <TextBlock Text="{Binding AssignedUser.FullName}"
                                                       Foreground="#7F8C8D"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Devam Eden -->
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <Border Background="#FEF9E7" CornerRadius="8"
                                        Padding="12,8" Margin="0,0,0,8">
                                    <TextBlock Text="⚡ Devam Ediyor"
                                               FontWeight="SemiBold"
                                               Foreground="#F39C12"/>
                                </Border>
                                <ItemsControl x:Name="InProgressList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                Cursor="Hand"
                                                Tag="{Binding}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="📌 Yapılacak'a Geri Al"
                                                          Click="MoveToTodo_Click"
                                                          Tag="{Binding}"/>
                                                        <MenuItem Header="✅ Tamamlandı'ya Taşı"
                                                          Click="MoveToDone_Click"
                                                          Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2C3E50"
                                                       FontSize="13"/>
                                                    <TextBlock Text="{Binding AssignedUser.FullName}"
                                                   Foreground="#7F8C8D"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Tamamlanan -->
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <Border Background="#E8F8F5" CornerRadius="8"
                                        Padding="12,8" Margin="0,0,0,8">
                                    <TextBlock Text="✅ Tamamlandı"
                                               FontWeight="SemiBold"
                                               Foreground="#27AE60"/>
                                </Border>
                                <ItemsControl x:Name="DoneList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KanbanCard}"
                                                Cursor="Hand"
                                                Tag="{Binding}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="📌 Yapılacak'a Geri Al"
                                                          Click="MoveToTodo_Click"
                                                          Tag="{Binding}"/>
                                                        <MenuItem Header="⚡ Devam Ediyor'a Taşı"
                                                          Click="MoveToInProgress_Click"
                                                          Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2C3E50"
                                                       FontSize="13"/>
                                                    <TextBlock Text="{Binding AssignedUser.FullName}"
                                                       Foreground="#7F8C8D"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Commit Geçmişi -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📜 Commit Geçmişi"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,12"/>

                        <ItemsControl x:Name="CommitsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    CornerRadius="16"
                                                    Background="#2C3E50">
                                                <TextBlock Text="{Binding User.FullName[0]}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Message}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding User.FullName}"
                                                           Foreground="#7F8C8D"
                                                           FontSize="11"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Progress -->
                                            <Border Grid.Column="2"
                                                    Background="#EBF5FB"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Progress,
                                                           StringFormat={}{0}/10}"
                                                           Foreground="#3498DB"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                            </Border>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding CreatedAt,
                                                              StringFormat=dd.MM.yyyy HH:mm}"
                                                       Foreground="#7F8C8D"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoCommitsText"
                                   Text="Henüz commit yapılmamış."
                                   Foreground="#BDC3C7"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,16"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Durum Güncelle -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="⚡ Durum Güncelle"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,16"/>

                        <!-- 1-10 Sayı Kutuları -->
                        <TextBlock Text="İlerleme Durumu:"
                                   FontSize="13" Foreground="#7F8C8D"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="1" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn1" Click="ProgressBtn_Click" Tag="1"/>
                            <Button Content="2" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn2" Click="ProgressBtn_Click" Tag="2"/>
                            <Button Content="3" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn3" Click="ProgressBtn_Click" Tag="3"/>
                            <Button Content="4" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn4" Click="ProgressBtn_Click" Tag="4"/>
                            <Button Content="5" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn5" Click="ProgressBtn_Click" Tag="5"/>
                            <Button Content="6" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn6" Click="ProgressBtn_Click" Tag="6"/>
                            <Button Content="7" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn7" Click="ProgressBtn_Click" Tag="7"/>
                            <Button Content="8" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn8" Click="ProgressBtn_Click" Tag="8"/>
                            <Button Content="9" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn9" Click="ProgressBtn_Click" Tag="9"/>
                            <Button Content="10" Style="{StaticResource ProgressBox}"
                                    x:Name="Btn10" Click="ProgressBtn_Click" Tag="10"/>
                        </StackPanel>

                        <!-- Progress Bar -->
                        <Grid Margin="0,0,0,16">
                            <ProgressBar x:Name="ProgressBarControl"
                                         Height="10"
                                         Minimum="0" Maximum="10"
                                         Value="1"
                                         Background="#ECF0F1"
                                         Foreground="#3498DB"/>
                        </Grid>

                        <TextBlock x:Name="ProgressDisplayText"
                                   Text="%10 Tamamlandı"
                                   FontSize="13"
                                   Foreground="#3498DB"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- Commit Mesajı -->
                        <TextBlock Text="Commit Mesajı:"
                                   FontSize="13" Foreground="#7F8C8D"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="CommitMessageBox"
                                 Height="80"
                                 Padding="12"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 BorderBrush="#BDC3C7"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock x:Name="CommitFeedback"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>

                        <Button Content="💾 Commit Gönder"
                                Style="{StaticResource ActionButton}"
                                HorizontalAlignment="Left"
                                Click="SubmitCommit_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>