<Window x:Class="TaskFlow.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        xmlns:models="clr-namespace:TaskFlow.Models"
        Title="TaskFlow — Admin Paneli"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.DataContext>
        <vm:AdminViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#2C3E50"/>
        <SolidColorBrush x:Key="Accent" Color="#3498DB"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                      Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button"
               BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Menü -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <TextBlock Text="⚡ TaskFlow"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,8"/>
                <TextBlock Text="Admin Paneli"
                           FontSize="11" Foreground="#95A5A6"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <Border Background="#34495E" CornerRadius="8" Margin="16,2">
                    <TextBlock Text="⚙️  Yönetim Paneli"
                               Foreground="White" FontSize="13"
                               Padding="16,12"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Ana İçerik -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,32,32,32">

                <TextBlock Text="Yönetim Paneli"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,24"/>

                <!-- DEPARTMAN YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🏢 Departman Yönetimi"
                                   Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Departman adı girin"
                                     Text="{Binding NewDepartmentName,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="+ Ekle"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding AddDepartmentCommand}"/>
                        </Grid>

                        <TextBlock Text="{Binding DepartmentMessage}"
                                   Foreground="#27AE60"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding Departments}"
                                 SelectedItem="{Binding SelectedDepartment}"
                                 MaxHeight="150"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Padding="8,4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Departmanı Sil"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteDepartmentCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- TAKIM YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Takım Yönetimi"
                                   Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Takım adı girin"
                                     Text="{Binding NewTeamName,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding Departments}"
                                      SelectedItem="{Binding NewTeamDepartment}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="+ Ekle"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding AddTeamCommand}"/>
                        </Grid>

                        <TextBlock Text="{Binding TeamMessage}"
                                   Foreground="#27AE60"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding Teams}"
                                 SelectedItem="{Binding SelectedTeam}"
                                 MaxHeight="150"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Padding="8,4"/>
                                        <TextBlock Text=" — "
                                                   Foreground="#7F8C8D"
                                                   Padding="0,4"/>
                                        <TextBlock Text="{Binding Department.Name}"
                                                   Foreground="#7F8C8D"
                                                   Padding="0,4"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Takımı Sil"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteTeamCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- KULLANICI YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👤 Kullanıcı Yönetimi"
                                   Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Kullanıcı adı"
                                     Text="{Binding NewUsername,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>

                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Ad Soyad"
                                     Text="{Binding NewFullName,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>

                            <TextBox Grid.Row="0" Grid.Column="2"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Şifre (min. 6 karakter)"
                                     Text="{Binding NewPassword,
                                            UpdateSourceTrigger=PropertyChanged}"/>

                            <ComboBox Grid.Row="2" Grid.Column="0"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding UserRoles}"
                                      SelectedItem="{Binding NewUserRole}"
                                      Margin="0,0,8,0"/>

                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding Departments}"
                                      SelectedItem="{Binding NewUserDepartment}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>

                            <ComboBox Grid.Row="2" Grid.Column="2"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding Teams}"
                                      SelectedItem="{Binding NewUserTeam}"
                                      DisplayMemberPath="Name"/>
                        </Grid>

                        <Button Content="+ Kullanıcı Ekle"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddUserCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,12"/>

                        <TextBlock Text="{Binding UserMessage}"
                                   Foreground="#27AE60"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding Users}"
                                 SelectedItem="{Binding SelectedUser}"
                                 MaxHeight="180"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FullName}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Username}"
                                                   Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Role}"
                                                   Foreground="#3498DB"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Team.Name}"
                                                   Foreground="#95A5A6"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Kullanıcıyı Sil"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteUserCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- PROJE YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📁 Proje Yönetimi"
                                   Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Proje adı"
                                     Text="{Binding NewProjectTitle,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>

                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Proje açıklaması"
                                     Text="{Binding NewProjectDescription,
                                            UpdateSourceTrigger=PropertyChanged}"/>

                            <ComboBox Grid.Row="2" Grid.Column="0"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding Teams}"
                                      SelectedItem="{Binding NewProjectTeam}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>

                            <DatePicker Grid.Row="2" Grid.Column="1"
                                        SelectedDate="{Binding NewProjectStartDate}"
                                        Height="36"
                                        Margin="0,0,8,0"/>
                        </Grid>

                        <Button Content="+ Proje Ekle"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddProjectCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,12"/>

                        <TextBlock Text="{Binding ProjectMessage}"
                                   Foreground="#27AE60"
                                   FontSize="12"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding Projects}"
                                 SelectedItem="{Binding SelectedProject}"
                                 MaxHeight="180"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Team.Name}"
                                                   Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Status}"
                                                   Foreground="#3498DB"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Projeyi Sil"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteProjectCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- GÖREV YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📋 Görev Yönetimi"
                   Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Görev adı -->
                            <TextBox Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource PlaceholderTextBox}"
                                Tag="Görev adı"
                                Text="{Binding NewTaskTitle,
                                    UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0"/>

                            <!-- Açıklama -->
                            <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 Tag="Görev açıklaması"
                                 Text="{Binding NewTaskDescription,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Proje seç -->
                            <ComboBox Grid.Row="2" Grid.Column="0"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding NewTaskProject}"
                      DisplayMemberPath="Title"
                      Margin="0,0,8,0"/>

                            <!-- Kullanıcı ata -->
                            <ComboBox Grid.Row="2" Grid.Column="1"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding NewTaskAssignedUser}"
                      DisplayMemberPath="FullName"/>

                            <!-- Öncelik -->
                            <ComboBox Grid.Row="4" Grid.Column="0"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding TaskPriorities}"
                      SelectedItem="{Binding NewTaskPriority}"
                      Margin="0,0,8,0"/>

                            <!-- Kategori -->
                            <ComboBox Grid.Row="4" Grid.Column="1"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding NewTaskCategory}"
                      DisplayMemberPath="Name"/>
                        </Grid>

                        <DatePicker SelectedDate="{Binding NewTaskDueDate}"
                    Height="36"
                    Margin="0,8,0,12"
                    HorizontalAlignment="Left"
                    Width="200"/>

                        <Button Content="+ Görev Ekle"
                Style="{StaticResource ActionButton}"
                Command="{Binding AddTaskCommand}"
                HorizontalAlignment="Left"
                Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding TaskMessage}"
                   Foreground="#27AE60"
                   FontSize="12"
                   Margin="0,0,0,12"/>

                        <!-- Görev Listesi -->
                        <TextBlock Text="Mevcut Görevler"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,8"/>

                        <ListBox ItemsSource="{Binding AllTasks}"
                 SelectedItem="{Binding SelectedTask}"
                 MaxHeight="200"
                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"/>

                                        <TextBlock Grid.Column="1"
                                   Text="{Binding Project.Title}"
                                   Foreground="#7F8C8D"
                                   FontSize="12"/>

                                        <!-- Öncelik rengi -->
                                        <Border Grid.Column="2"
                                CornerRadius="4"
                                Padding="6,2"
                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FDEBD0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="High">
                                                            <Setter Property="Background" Value="#FADBD8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                            <Setter Property="Background" Value="#F1948A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                            <Setter Property="Background" Value="#D5F5E3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Priority}"
                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>

                                        <TextBlock Grid.Column="3"
                                   Text="{Binding Status}"
                                   Foreground="#3498DB"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                   Text="{Binding AssignedUser.FullName}"
                                   Foreground="#95A5A6"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Görevi Sil"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteTaskCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- PROJE ÜYE YÖNETİMİ -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Projeye Üye Ekle"
                   Style="{StaticResource SectionTitle}"/>

                        <!-- Proje ve Kullanıcı Seçimi -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding SelectedProjectForMember}"
                      DisplayMemberPath="Title"
                      Margin="0,0,8,0"/>

                            <ComboBox Grid.Column="1"
                      Style="{StaticResource ComboStyle}"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUserForProject}"
                      DisplayMemberPath="FullName"
                      Margin="0,0,8,0"/>

                            <Button Grid.Column="2"
                    Content="+ Ekle"
                    Style="{StaticResource ActionButton}"
                    Command="{Binding AddMemberToProjectCommand}"/>
                        </Grid>

                        <TextBlock Text="{Binding MemberMessage}"
                   Foreground="#27AE60"
                   FontSize="12"
                   Margin="0,0,0,12"/>

                        <!-- Seçili Projenin Üyeleri -->
                        <TextBlock FontSize="13"
                   Foreground="#7F8C8D"
                   Margin="0,0,0,8">
            <Run Text="Proje üyeleri: "/>
            <Run Text="{Binding SelectedProjectForMember.Title}"
                 Foreground="#2C3E50" FontWeight="SemiBold"/>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding ProjectMembers}"
                 MaxHeight="180"
                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4" Width="500">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Grid.Column="0"
                                Width="30" Height="30"
                                CornerRadius="15"
                                Background="#3498DB">
                                            <TextBlock Text="{Binding User.FullName[0]}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- İsim -->
                                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding User.FullName}"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                                            <TextBlock Text="{Binding User.Username}"
                                       Foreground="#7F8C8D"
                                       FontSize="11"/>
                                        </StackPanel>

                                        <!-- Rol -->
                                        <Border Grid.Column="2"
                                Background="#EBF5FB"
                                CornerRadius="4"
                                Padding="8,4"
                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding User.Role}"
                                       Foreground="#3498DB"
                                       FontSize="11"/>
                                        </Border>

                                        <!-- Çıkar butonu -->
                                        <Button Grid.Column="3"
                                Content="Çıkar"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DataContext.RemoveMemberFromProjectCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Height="28"
                                FontSize="11"
                                Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Üye yoksa -->
                        <TextBlock Text="Bu projeye henüz üye eklenmemiş."
                   Foreground="#BDC3C7"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProjectMembers.Count}"
                                     Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>