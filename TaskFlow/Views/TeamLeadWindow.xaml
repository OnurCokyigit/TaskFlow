<Window x:Class="TaskFlow.Views.TeamLeadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        Title="TaskFlow — Takım Yönetimi"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.DataContext>
        <vm:TeamLeadViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                      Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button"
               BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Menü -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,32,0,40">
                    <TextBlock Text="⚡ TaskFlow"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Takım Kaptanı"
                               FontSize="11" Foreground="#95A5A6"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,0">
                    <Border Background="#34495E" CornerRadius="8" Margin="0,2">
                        <TextBlock Text="🏠  Dashboard"
                                   Foreground="White" FontSize="13"
                                   Padding="16,12"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,24">
                    <TextBlock Text="{Binding FullName}"
                               Foreground="#BDC3C7" FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <Button Content="Çıkış Yap"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Height="36"
                            Cursor="Hand"
                            Click="Logout_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Ana İçerik -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,32,32,32">

                <!-- Başlık -->
                <TextBlock FontSize="22" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,4">
                    <Run Text="Hoş geldin, "/>
                    <Run Text="{Binding FullName}" Foreground="#3498DB"/>
                </TextBlock>
                <TextBlock Text="Takımınıza ait güncel durum:"
                           Foreground="#7F8C8D" FontSize="13"
                           Margin="0,0,0,28"/>

                <!-- İstatistik Kartları -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White"
                            CornerRadius="10" Padding="24" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                              Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalProjects}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Takım Projesi"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White"
                            CornerRadius="10" Padding="24" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                              Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalTasks}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Toplam Görev"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White"
                            CornerRadius="10" Padding="24" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                              Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="✅" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CompletedTasks}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2ECC71"/>
                            <TextBlock Text="Tamamlanan"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="White"
                            CornerRadius="10" Padding="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2"
                                              Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="22" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalMembers}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="Takım Üyesi"
                                       Foreground="#7F8C8D" FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tamamlanma Oranı -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📊 Takım Tamamlanma Oranı"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CompletionRateDisplay}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#3498DB"/>
                        </Grid>
                        <ProgressBar Height="12" Minimum="0" Maximum="100"
                                     Value="{Binding CompletionRate}"
                                     Background="#ECF0F1"
                                     Foreground="#3498DB"/>
                    </StackPanel>
                </Border>

                <!-- Proje Durumları -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📁 Takım Projeleri"
                                   Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding ProjectSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,12"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ProjectCard_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2C3E50"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="16,0">
                                                <ProgressBar Height="8"
                                                             Minimum="0" Maximum="100"
                                                             Value="{Binding Progress}"
                                                             Background="#ECF0F1"
                                                             Foreground="#3498DB"
                                                             Margin="0,0,0,4"/>
                                                <TextBlock Foreground="#7F8C8D"
                                                           FontSize="11">
                                                    <Run Text="{Binding CompletedTasks}"/>
                                                    <Run Text="/"/>
                                                    <Run Text="{Binding TotalTasks}"/>
                                                    <Run Text=" görev"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ProgressDisplay}"
                                                       Foreground="#3498DB"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Son Aktiviteler -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📜 Son Aktiviteler"
                                   Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding RecentCommits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    CornerRadius="16"
                                                    Background="#2C3E50">
                                                <TextBlock Text="{Binding User.FullName[0]}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Message}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding User.FullName}"
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"/>
                                                    <TextBlock Text=" · "
                                                               Foreground="#7F8C8D"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Project.Title}"
                                                               Foreground="#3498DB"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    Background="#EBF5FB"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Progress,
                                                           StringFormat={}{0}/10}"
                                                           Foreground="#3498DB"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                            </Border>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding CreatedAt,
                                                              StringFormat=dd.MM.yyyy HH:mm}"
                                                       Foreground="#7F8C8D"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Proje Oluştur -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📁 Proje Oluştur"
                                   Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Proje adı"
                                     Text="{Binding NewProjectTitle,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Proje açıklaması"
                                     Text="{Binding NewProjectDescription,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <DatePicker Grid.Column="2"
                                        SelectedDate="{Binding NewProjectStartDate}"
                                        Height="36"
                                        Margin="0,0,8,0"/>
                            <Button Grid.Column="3"
                                    Content="+ Oluştur"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding AddProjectCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding ProjectMessage}"
                                   Foreground="#27AE60" FontSize="12"
                                   Margin="0,8,0,0"/>

                        <ListBox ItemsSource="{Binding MyProjects}"
                            SelectedItem="{Binding SelectedProject}"
                            MaxHeight="160"
                            BorderBrush="#ECF0F1"
                            Margin="0,8,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                            Text="{Binding Title}"
                                            FontWeight="SemiBold"
                                            Foreground="#2C3E50"
                                            VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                           Text="{Binding Status}"
                                           Foreground="#3498DB"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Projeyi Sil"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteProjectCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>

                    </StackPanel>
                </Border>

                <!-- Projeye Üye Ekle -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Projeye Üye Ekle / Çıkar"
                                   Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding MyProjects}"
                                      SelectedItem="{Binding SelectedProject}"
                                      DisplayMemberPath="Title"
                                      Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding TeamMembers}"
                                      SelectedItem="{Binding SelectedUserForProject}"
                                      DisplayMemberPath="FullName"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="+ Ekle"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding AddMemberToProjectCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding MemberMessage}"
                                   Foreground="#27AE60" FontSize="12"
                                   Margin="0,0,0,12"/>
                        <ListBox ItemsSource="{Binding ProjectMembers}"
                                 MaxHeight="150"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="30" Height="30"
                                                CornerRadius="15"
                                                Background="#3498DB">
                                            <TextBlock Text="{Binding User.FullName[0]}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding User.FullName}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Content="Çıkar"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.RemoveMemberFromProjectCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Height="28" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Görev Yönetimi -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📋 Görev Yönetimi"
                                   Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Görev adı"
                                     Text="{Binding NewTaskTitle,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Görev açıklaması"
                                     Text="{Binding NewTaskDescription,
                                            UpdateSourceTrigger=PropertyChanged}"/>

                            <ComboBox Grid.Row="2" Grid.Column="0"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding MyProjects}"
                                      SelectedItem="{Binding SelectedProject}"
                                      DisplayMemberPath="Title"
                                      Margin="0,0,8,0"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding TeamMembers}"
                                      SelectedItem="{Binding NewTaskAssignedUser}"
                                      DisplayMemberPath="FullName"/>

                            <ComboBox Grid.Row="4" Grid.Column="0"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding TaskPriorities}"
                                      SelectedItem="{Binding NewTaskPriority}"
                                      Margin="0,0,8,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      Style="{StaticResource ComboStyle}"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding NewTaskCategory}"
                                      DisplayMemberPath="Name"/>
                        </Grid>

                        <Button Content="+ Görev Ekle"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding AddTaskCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,12"/>

                        <TextBlock Text="{Binding TaskMessage}"
                                   Foreground="#27AE60" FontSize="12"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding TeamTasks}"
                                 SelectedItem="{Binding SelectedTask}"
                                 MaxHeight="200"
                                 BorderBrush="#ECF0F1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2C3E50"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Project.Title}"
                                                   Foreground="#7F8C8D"
                                                   FontSize="12"/>
                                        <Border Grid.Column="2"
                                                CornerRadius="4" Padding="6,2"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FDEBD0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="High">
                                                            <Setter Property="Background" Value="#FADBD8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                            <Setter Property="Background" Value="#F1948A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                            <Setter Property="Background" Value="#D5F5E3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Priority}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Status}"
                                                   Foreground="#3498DB"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding AssignedUser.FullName}"
                                                   Foreground="#95A5A6"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Seçili Görevi Sil"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteTaskCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>